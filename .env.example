# Environment Variables Template
# Copy this file to .env for local development
# Adrienne's Personal Website

# Node environment (development or production)
NODE_ENV=development

# Server port
PORT=3000

# Public site URL for canonical SEO tags and sitemap (optional, recommended in production)
# SITE_URL=https://example.com

# Database URL (PostgreSQL)
# For local development: postgresql://user:password@localhost:5432/adrienne_personal_site
# For production (Render): This will be auto-set by Render
# DATABASE_URL=postgresql://user:password@host:5432/adrienne_personal_site

# Logging level (optional)
LOG_LEVEL=info

# Spotify API credentials (for /building now playing widget)
# SPOTIFY_CLIENT_ID=your_client_id
# SPOTIFY_CLIENT_SECRET=your_client_secret
# SPOTIFY_REFRESH_TOKEN=your_refresh_token

# Google Drive library sync (for /library page)
# GOOGLE_DRIVE_FOLDER_IDS=folder_id_or_url,another_folder_id_or_url
# Preferred for private/shared Drive folders. Share the Drive folder with the service account client_email.
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...@....iam.gserviceaccount.com"}
# API-key auth only works for Drive content that is public to the API.
# GOOGLE_DRIVE_API_KEY=your_google_api_key_here
# LIBRARY_SYNC_INTERVAL_MINUTES=60

# Writing submissions admin endpoint security
# Required to enable /admin/writing-submissions and /admin/writing-submissions.csv
# ADMIN_USERNAME=change_me
# ADMIN_PASSWORD=use_a_long_random_password
# Optional: comma-separated IP allowlist (for example: 203.0.113.10,198.51.100.5)
# ADMIN_ALLOWED_IPS=
