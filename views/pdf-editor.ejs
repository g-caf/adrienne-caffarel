<%- include('partials/head', { title, pageDescription, canonicalPath, canonicalUrl, seoJsonLd, siteUrl }) %>
<body>
  <div class="page-container pdf-editor-page">
    <%- include('partials/header') %>

    <main>
      <section class="pdf-editor-hero">
        <p class="pdf-editor-hero__eyebrow">Developing</p>
        <h1 class="pdf-editor-hero__title">PDF Editor & Signing Tool</h1>
        <div class="pdf-editor-hero__copy">
          <p>
            This is a browser-based PDF editor for merging files, reordering pages, dropping sections, placing text, adding signatures,
            and working with form fields without leaving the site.
          </p>
          <p>
          It is also embedded on the <a href="/building">Building</a> page, but this standalone URL exists so the tool can be
            discovered and indexed as its own page.
          </p>
        </div>
      </section>

      <section class="pdf-editor-page__tool">
        <%- include('partials/pdf-editor-embed', { showFullPageLink: false }) %>
      </section>
    </main>

    <%- include('partials/footer') %>
  </div>

  <script src="/js/animations.js"></script>
</body>
</html>
