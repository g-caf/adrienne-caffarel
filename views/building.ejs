<%- include('partials/head', { title: pageTitle, extraStyles: buildingPageSuspended ? [] : ['/pdf-tool/assets/index-Mjgm8SgZ.css'] }) %>
<body>
  <div class="page-container building-page <%= buildingPageSuspended ? 'building-page--suspended' : '' %>">
    <%- include('partials/header') %>

    <main <%= buildingPageSuspended ? 'aria-hidden="true" inert' : '' %>>
      <% (buildingBlocks || []).forEach((block) => { %>
        <% if (block.type === 'intro') { %>
          <section class="building-intro">
            <p class="building-intro__line"><%- block.lineHtml %></p>
          </section>
        <% } else if (block.type === 'columns_primary') { %>
          <section class="building-columns">
            <p><%- block.leftHtml %></p>
            <p><%- block.rightHtml %></p>
          </section>
        <% } else if (block.type === 'spotify') { %>
          <section class="building-spotify" aria-live="polite">
            <p class="building-spotify__title"><%- block.titleHtml %></p>
            <div class="spotify-card" data-spotify-card>
              <div class="spotify-card__art">
                <img src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=" alt="" data-spotify-art loading="lazy">
              </div>
              <div class="spotify-card__meta">
                <p class="spotify-card__status" data-spotify-status>Loading Spotify…</p>
                <h3 class="spotify-card__track" data-spotify-track></h3>
                <p class="spotify-card__artist" data-spotify-artist></p>
                <a class="spotify-card__link" data-spotify-link href="" target="_blank" rel="noreferrer">Open in Spotify</a>
              </div>
            </div>
          </section>
        <% } else if (block.type === 'columns_secondary') { %>
          <section class="building-columns building-columns--secondary">
            <p><%- block.leftHtml %></p>
            <p><%- block.rightHtml %></p>
          </section>
        <% } else if (block.type === 'visitors') { %>
          <section class="building-visitors">
            <p class="building-visitors__copy"><%- block.copyHtml %></p>
            <div class="building-visitors__count" aria-live="polite" data-visitor-count>
              <%= typeof uniqueVisitors !== 'undefined' ? uniqueVisitors : 0 %>
            </div>
            <p class="building-visitors__contact"><%- block.contactHtml %></p>
          </section>
        <% } else if (block.type === 'pdf_intro') { %>
          <section class="building-pdf-intro">
            <p class="building-pdf-intro__title"><%- block.titleHtml %></p>
            <div class="building-pdf-download">
              <a class="building-pdf-download__button" href="<%= block.ctaHref %>"><%- block.ctaLabelHtml %></a>
              <p class="building-pdf-download__note"><%- block.noteHtml %></p>
            </div>
            <div class="building-pdf-intro__columns">
              <p><%- block.leftHtml %></p>
              <p><%- block.rightHtml %></p>
            </div>
          </section>
        <% } else if (block.type === 'pdf_app') { %>
          <section class="building-pdf">
            <% if (!buildingPageSuspended) { %>
              <div id="pdf-tool-app" class="pdf-tool-shell" aria-label="Embedded PDF editor"></div>
            <% } else { %>
              <div class="pdf-tool-shell pdf-tool-shell--suspended" aria-hidden="true"></div>
            <% } %>
          </section>
        <% } %>
      <% }) %>
    </main>

    <% if (buildingPageSuspended) { %>
      <section class="building-suspend-wrap" aria-label="Building page suspended">
        <div class="writing-gate-card building-suspend-card">
          <div class="writing-lock-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img" focusable="false">
              <path class="lock-body" d="M7 10h10a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2Z"/>
              <path class="lock-shackle" d="M9 10V7.75a3 3 0 1 1 6 0V10" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </div>
          <p class="building-suspend-card__eyebrow">Building</p>
          <p class="building-suspend-card__copy">This page is locked while I rework it.</p>
          <p class="building-suspend-card__copy">Check back soon.</p>
        </div>
      </section>
    <% } %>
  </div>

  <script src="/js/animations.js"></script>
  <script src="/js/building.js"></script>
  <% if (!buildingPageSuspended) { %>
    <script type="module" src="/pdf-tool/assets/index-T63kGvLd.js"></script>
  <% } %>
</body>
</html>
