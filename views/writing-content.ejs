<%- include('partials/head', { title: pageTitle || 'Writing', pageDescription, canonicalPath, canonicalUrl, seoJsonLd, siteUrl }) %>
<body>
  <div class="page-container writing-page">
    <%- include('partials/header') %>

    <main>
      <section class="writing-content-section writing-editorial" data-writing-editorial>
        <div class="writing-mobile-tabs" role="tablist" aria-label="Writing sections">
          <button
            type="button"
            class="writing-mobile-tab is-active"
            data-writing-tab="orienting"
            role="tab"
            aria-selected="true"
          >
            <%= (orienting && orienting.heading) || 'Orienting' %>
          </button>
          <button
            type="button"
            class="writing-mobile-tab"
            data-writing-tab="thinking"
            role="tab"
            aria-selected="false"
          >
            <%= (thinking && thinking.heading) || 'Thinking' %>
          </button>
        </div>

        <div class="writing-columns" data-writing-columns>
          <article class="writing-column writing-column-orienting is-active" data-writing-pane="orienting">
            <header class="writing-column-header">
              <h2 class="writing-column-heading"><%= (orienting && orienting.heading) || 'Orienting' %></h2>
            </header>
            <% if (orienting && orienting.lede) { %>
              <p class="writing-column-lede"><%= orienting.lede %></p>
            <% } %>
            <% (orienting && orienting.paragraphs ? orienting.paragraphs : []).forEach((paragraph) => { %>
              <p class="writing-column-paragraph"><%= paragraph %></p>
            <% }) %>
          </article>

          <article class="writing-column writing-column-thinking" data-writing-pane="thinking">
            <header class="writing-column-header writing-column-header-right">
              <h2 class="writing-column-heading"><%= (thinking && thinking.heading) || 'Thinking' %></h2>
            </header>
            <% if (thinking && thinking.title) { %>
              <p class="writing-column-subtitle"><%= thinking.title %></p>
            <% } %>
            <% (thinking && thinking.paragraphs ? thinking.paragraphs : []).forEach((paragraph) => { %>
              <p class="writing-column-paragraph"><%= paragraph %></p>
            <% }) %>
          </article>
        </div>
      </section>
    </main>

    <%- include('partials/footer') %>
  </div>

  <script src="/js/animations.js"></script>
  <script src="/js/writing-tabs.js"></script>
</body>
</html>
