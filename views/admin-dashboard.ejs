<%- include('partials/head', { title, pageDescription, canonicalPath, canonicalUrl, seoJsonLd, siteUrl }) %>
<body>
  <div class="page-container admin-submissions-page">
    <main class="admin-submissions-main">
      <section class="admin-submissions-shell">
        <header class="admin-submissions-header">
          <div>
            <p class="admin-submissions-kicker">Admin</p>
            <h1>Writing Dashboard</h1>
          </div>
          <div class="admin-submissions-links">
            <a href="/writing" target="_blank" rel="noopener noreferrer">Open Writing Page</a>
            <a href="/admin/writing-submissions.csv?limit=1000">Download CSV</a>
          </div>
        </header>

        <section class="admin-editor-panel">
          <h2>Writing Page Content</h2>
          <% if (saved) { %>
            <p class="admin-editor-flash">Saved changes.</p>
          <% } %>
          <form method="post" action="/admin/writing-content" class="admin-editor-form">
            <label for="admin-writing-title">Title</label>
            <input
              id="admin-writing-title"
              name="title"
              type="text"
              required
              value="<%= (writingPage && writingPage.title) || 'Writing' %>"
            >

            <label for="admin-orienting-heading">Orienting Heading</label>
            <input
              id="admin-orienting-heading"
              name="orienting_heading"
              type="text"
              required
              value="<%= (writingData && writingData.orienting && writingData.orienting.heading) || 'Orienting' %>"
            >

            <label for="admin-orienting-lede">Orienting Lead Line</label>
            <input
              id="admin-orienting-lede"
              name="orienting_lede"
              type="text"
              value="<%= (writingData && writingData.orienting && writingData.orienting.lede) || '' %>"
            >

            <label for="admin-orienting-content">Orienting Body</label>
            <textarea
              id="admin-orienting-content"
              name="orienting_content"
              rows="8"
            ><%= (writingData && writingData.orienting && writingData.orienting.content) || '' %></textarea>

            <label for="admin-thinking-heading">Thinking Heading</label>
            <input
              id="admin-thinking-heading"
              name="thinking_heading"
              type="text"
              required
              value="<%= (writingData && writingData.thinking && writingData.thinking.heading) || 'Thinking' %>"
            >

            <label for="admin-thinking-title">Thinking Title</label>
            <input
              id="admin-thinking-title"
              name="thinking_title"
              type="text"
              value="<%= (writingData && writingData.thinking && writingData.thinking.title) || '' %>"
            >

            <label for="admin-thinking-content">Thinking Body</label>
            <textarea
              id="admin-thinking-content"
              name="thinking_content"
              rows="9"
              required
            ><%= (writingData && writingData.thinking && writingData.thinking.content) || 'Private essays archive. New pieces coming soon.' %></textarea>

            <button type="submit">Save Writing Page</button>
          </form>
        </section>

        <section>
          <div class="admin-submissions-stats">
            <article class="admin-submissions-stat">
              <p>Total Loaded</p>
              <strong><%= total %></strong>
            </article>
            <article class="admin-submissions-stat">
              <p>Unique Emails</p>
              <strong><%= uniqueEmailCount %></strong>
            </article>
            <article class="admin-submissions-stat">
              <p>Last 24 Hours</p>
              <strong><%= last24HoursCount %></strong>
            </article>
          </div>

          <div class="admin-submissions-table-wrap">
            <table class="admin-submissions-table">
              <thead>
                <tr>
                  <th>Submitted</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>IP</th>
                  <th>User Agent</th>
                </tr>
              </thead>
              <tbody>
                <% if (!submissions || submissions.length === 0) { %>
                  <tr>
                    <td colspan="5" class="admin-submissions-empty">No submissions yet.</td>
                  </tr>
                <% } %>
                <% (submissions || []).forEach((row) => { %>
                  <tr>
                    <td><%= row.created_at || '' %></td>
                    <td><%= [row.first_name, row.last_name].filter(Boolean).join(' ') %></td>
                    <td><a href="mailto:<%= row.email %>"><%= row.email %></a></td>
                    <td><%= row.source_ip || '' %></td>
                    <td class="admin-submissions-agent"><%= row.user_agent || '' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  </div>
</body>
</html>
