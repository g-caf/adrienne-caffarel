<%- include('partials/head', { title: 'Home' }) %>
<body>
  <!-- Landing Page with Animation -->
  <div class="landing-page">
    <div class="landing-container">
      <p class="intro-text">
        <span class="intro-text-part">Hi, I'm Adrienne. I've been</span>
        <span class="word-flip"></span>
      </p>
      <div class="accent-line"></div>
      <button class="landing-down-arrow" type="button" aria-label="Enter site"></button>
    </div>
  </div>

  <!-- Main Page Content (Hidden until animation completes) -->
  <div class="page-container preload-hidden">
    <%- include('partials/header') %>
    
    <main>
      <section class="feeds-section">
        <h2 class="section-title">What's happening</h2>
        <div class="feed-map-control" data-feed-map>
          <button
            type="button"
            class="feed-map-toggle"
            data-feed-map-toggle
            aria-expanded="false"
            aria-controls="feed-map-sources feed-map-hubs"
            aria-label="Open feed and hub map"
          >
            +
          </button>
          <p id="feed-map-sources" class="feed-map-ribbon feed-map-ribbon-horizontal">
            Aggregated RSS feeds from:
            <span><%= (feedSourceNames || []).join(', ') %></span>
          </p>
          <nav id="feed-map-hubs" class="feed-map-ribbon feed-map-ribbon-vertical" aria-label="Topic hubs">
            <% (topicHubs || []).forEach((hub) => { %>
              <a href="<%= hub.path %>"><%= hub.title %></a>
            <% }) %>
          </nav>
        </div>
        <nav class="sr-only" aria-label="Topic hubs fallback">
          <% (topicHubs || []).forEach((hub) => { %>
            <a href="<%= hub.path %>"><%= hub.title %></a>
          <% }) %>
        </nav>
        <ul class="articles-grid">
          <%- include('partials/articles-grid', { articles }) %>
        </ul>
      </section>
    </main>

    <%- include('partials/footer') %>
  </div>

  <script src="/js/animations.js"></script>
  <script src="/js/feed-map-toggle.js"></script>
  <script src="/js/analytics-client.js"></script>
</body>
</html>
