<%- include('partials/head', { title, pageDescription, canonicalPath, canonicalUrl, seoJsonLd, siteUrl }) %>
<body>
  <div class="page-container topic-page">
    <%- include('partials/header') %>

    <main>
      <section class="topic-hub-bar" aria-label="Hub">
        <h1 class="topic-hub-bar-title"><%= topicTitle %></h1>
      </section>
      <section class="feeds-section">
        <p class="feed-sources-subtitle">
          Aggregated RSS feeds from:
          <span><%= (feedSourceNames || []).join(', ') %></span>
        </p>
        <ul class="articles-grid">
          <%- include('partials/articles-grid', { articles }) %>
        </ul>
      </section>
    </main>

    <%- include('partials/footer') %>
  </div>

  <script src="/js/animations.js"></script>
  <script src="/js/analytics-client.js"></script>
</body>
</html>
