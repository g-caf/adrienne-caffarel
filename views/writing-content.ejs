<%- include('partials/head', { title: pageTitle || 'Writing', pageDescription, canonicalPath, canonicalUrl, seoJsonLd, siteUrl }) %>
<body>
  <div class="page-container writing-page">
    <%- include('partials/header') %>

    <main>
      <section class="writing-content-section">
        <h2 class="writing-content-title"><%= pageTitle || 'Writing' %></h2>
        <% if (!contentParagraphs || contentParagraphs.length === 0) { %>
          <p class="writing-content-note">Private essays archive. New pieces coming soon.</p>
        <% } %>
        <% (contentParagraphs || []).forEach((paragraph) => { %>
          <p class="writing-content-note"><%= paragraph %></p>
        <% }) %>
      </section>
    </main>

    <%- include('partials/footer') %>
  </div>

  <script src="/js/animations.js"></script>
</body>
</html>
