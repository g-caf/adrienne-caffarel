<%- include('partials/head', { title, pageDescription, canonicalPath, canonicalUrl, seoJsonLd, siteUrl }) %>
<body>
  <div class="page-container writing-page admin-writing-page">
    <%- include('partials/header') %>

    <main>
      <section class="writing-content-section writing-editorial admin-writing-shell">
        <header class="admin-writing-header">
          <h2 class="writing-column-heading">Writing Admin</h2>
          <p>
            <a href="/admin/analytics">Analytics Dashboard</a>
            <span aria-hidden="true"> / </span>
            <a href="/admin/writing-submissions.csv?limit=1000">Download CSV</a>
          </p>
        </header>

        <% if (saved) { %>
          <p class="admin-editor-flash">Saved <%= savedSection || 'entry' %>.</p>
        <% } %>
        <% if (librarySyncMessage) { %>
          <p class="admin-editor-flash"><%= librarySyncMessage %></p>
        <% } %>

        <div class="admin-library-sync">
          <form method="post" action="/admin/library-sync">
            <button type="submit">Sync Library</button>
          </form>
          <div class="admin-library-sync-meta">
            <% if (librarySyncStatus && librarySyncStatus.lastSyncCompletedAt) { %>
              <p>Last sync: <%= librarySyncStatus.lastSyncCompletedAt %></p>
            <% } else { %>
              <p>No library sync recorded yet.</p>
            <% } %>
            <% if (librarySyncStatus && librarySyncStatus.lastSyncError) { %>
              <p class="admin-library-sync-error">Last error: <%= librarySyncStatus.lastSyncError %></p>
            <% } %>
          </div>
        </div>

        <section class="admin-building">
          <h3 class="writing-column-heading">Building Page</h3>
          <p class="admin-submissions-meta">Drag to reorder. Markdown supported.</p>
          <ol class="admin-building-order" data-building-order-list>
            <% (buildingBlocks || []).forEach((block) => { %>
              <li class="admin-building-order__item" draggable="true" data-building-slug="<%= block.slug %>">
                <div class="admin-building-order__header">
                  <span class="admin-building-order__handle" data-building-handle aria-hidden="true">drag</span>
                  <span class="admin-building-order__title"><%= block.label %></span>
                </div>
                <% if (block.editable) { %>
                  <form method="post" action="/admin/building-content" class="admin-editor-form">
                    <input type="hidden" name="slug" value="<%= block.slug %>">
                    <% (block.fields || []).forEach((field) => { %>
                      <label for="admin-building-<%= block.slug %>-<%= field.name %>"><%= field.label %></label>
                      <textarea
                        id="admin-building-<%= block.slug %>-<%= field.name %>"
                        name="<%= field.name %>"
                        rows="<%= field.rows || 3 %>"
                        required
                      ><%= field.value || '' %></textarea>
                    <% }) %>
                    <div class="admin-editor-actions">
                      <button type="submit">Save</button>
                    </div>
                  </form>
                <% } else { %>
                  <p class="admin-submissions-meta">This block is reorder-only.</p>
                <% } %>
              </li>
            <% }) %>
          </ol>
          <form method="post" action="/admin/building-order" class="admin-editor-form admin-building-order-form">
            <input
              type="hidden"
              name="order"
              value="<%= (buildingBlocks || []).map((block) => block.slug).join(',') %>"
              data-building-order-input
            >
            <div class="admin-editor-actions">
              <button type="submit">Save order</button>
            </div>
          </form>
        </section>

        <div class="admin-writing-grid">
          <section class="admin-writing-feed">
            <h3 class="writing-column-heading">Orienting</h3>
            <form method="post" action="/admin/writing-content" class="admin-editor-form">
              <input type="hidden" name="section" value="orienting">
              <% if (orientingEditingId) { %>
                <input type="hidden" name="entry_id" value="<%= orientingEditingId %>">
              <% } %>
              <label for="admin-orienting-content">Orienting (Markdown)</label>
              <textarea id="admin-orienting-content" name="content" rows="14" required><%= orientingDraft || '' %></textarea>
              <div class="admin-editor-actions">
                <button type="submit"><%= orientingEditingId ? 'Update' : 'Post' %></button>
                <% if (orientingEditingId) { %>
                  <a href="/admin">Clear</a>
                <% } %>
              </div>
            </form>

            <div class="admin-submissions-table-wrap admin-writing-table-wrap">
              <table class="admin-submissions-table admin-writing-table">
                <thead>
                  <tr>
                    <th>Posted</th>
                    <th>Excerpt</th>
                    <th>Edit</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!orientingEntries || orientingEntries.length === 0) { %>
                    <tr>
                      <td colspan="3" class="admin-submissions-empty">No orienting posts yet.</td>
                    </tr>
                  <% } %>
                  <% (orientingEntries || []).forEach((row) => { %>
                    <tr>
                      <td><%= row.created_at || '' %></td>
                      <td><%= row.summary %></td>
                      <td><a href="/admin?orienting_edit=<%= row.id %>">Edit</a></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>

          <section class="admin-writing-feed">
            <h3 class="writing-column-heading">Thinking</h3>
            <form method="post" action="/admin/writing-content" class="admin-editor-form">
              <input type="hidden" name="section" value="thinking">
              <% if (thinkingEditingId) { %>
                <input type="hidden" name="entry_id" value="<%= thinkingEditingId %>">
              <% } %>
              <label for="admin-thinking-content">Thinking (Markdown)</label>
              <textarea id="admin-thinking-content" name="content" rows="14" required><%= thinkingDraft || '' %></textarea>
              <div class="admin-editor-actions">
                <button type="submit"><%= thinkingEditingId ? 'Update' : 'Post' %></button>
                <% if (thinkingEditingId) { %>
                  <a href="/admin">Clear</a>
                <% } %>
              </div>
            </form>

            <div class="admin-submissions-table-wrap admin-writing-table-wrap">
              <table class="admin-submissions-table admin-writing-table">
                <thead>
                  <tr>
                    <th>Posted</th>
                    <th>Excerpt</th>
                    <th>Edit</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!thinkingEntries || thinkingEntries.length === 0) { %>
                    <tr>
                      <td colspan="3" class="admin-submissions-empty">No thinking posts yet.</td>
                    </tr>
                  <% } %>
                  <% (thinkingEntries || []).forEach((row) => { %>
                    <tr>
                      <td><%= row.created_at || '' %></td>
                      <td><%= row.summary %></td>
                      <td><a href="/admin?thinking_edit=<%= row.id %>">Edit</a></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>
        </div>

        <section class="admin-submissions-simple admin-submissions-public">
          <h3 class="writing-column-heading">Gate Submissions</h3>
          <p class="admin-submissions-meta"><%= total %> loaded.</p>
          <div class="admin-submissions-table-wrap">
            <table class="admin-submissions-table">
              <thead>
                <tr>
                  <th>Submitted</th>
                  <th>Name</th>
                  <th>Email</th>
                </tr>
              </thead>
              <tbody>
                <% if (!submissions || submissions.length === 0) { %>
                  <tr>
                    <td colspan="3" class="admin-submissions-empty">No submissions yet.</td>
                  </tr>
                <% } %>
                <% (submissions || []).forEach((row) => { %>
                  <tr>
                    <td><%= row.created_at || '' %></td>
                    <td><%= [row.first_name, row.last_name].filter(Boolean).join(' ') %></td>
                    <td><a href="mailto:<%= row.email %>"><%= row.email %></a></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>

    <%- include('partials/footer') %>
  </div>
  <script src="/js/admin-building.js"></script>
</body>
</html>
